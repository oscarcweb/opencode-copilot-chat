{
  "name": "opencodego-vscode",
  "displayName": "OpenCode Go BYOK Provider",
  "description": "Adds OpenCode Go models to VS Code and GitHub Copilot Chat through the Language Model Chat Provider API. Bring your own API key (BYOK).",
  "version": "0.1.0",
  "publisher": "ltmoerdani",
  "license": "MIT",
  "icon": "media/opencodego.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "keywords": [
    "opencode",
    "copilot",
    "byok",
    "ai",
    "language model",
    "openai",
    "llm",
    "chat"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ltmoerdani/opencode-go-copilot.git"
  },
  "bugs": {
    "url": "https://github.com/ltmoerdani/opencode-go-copilot/issues"
  },
  "homepage": "https://github.com/ltmoerdani/opencode-go-copilot#readme",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelChatProvider:opencodego"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "opencodego.manage",
        "title": "OpenCode Go: Manage Provider"
      },
      {
        "command": "opencodego.setApiKey",
        "title": "OpenCode Go: Set API Key"
      },
      {
        "command": "opencodego.diagnostics",
        "title": "OpenCode Go: Diagnostics"
      }
    ],
    "configuration": {
      "title": "OpenCode Go",
      "properties": {
        "opencodego.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature used for chat completions."
        },
        "opencodego.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional max output token override. Use 0 to request each OpenCode Go model's configured maximum."
        },
        "opencodego.maxInputTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional context size override advertised to VS Code. Use 0 to advertise each OpenCode Go model's configured context window."
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "opencodego",
        "displayName": "OpenCode Go",
        "configuration": "opencodego"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/vscode": "^1.118.0",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^5.9.3"
  }
}
